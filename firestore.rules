rules_version = '2';
// Regras de exemplo para o Firestore — ajuste no console do Firebase.
// Admin: apenas quem tiver email == kingoversized@gmail.com pode escrever em /products.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "kingoversized@gmail.com";
    }

    // Produtos — leitura pública; escrita apenas do admin
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Usuários — cada um lê/escreve seu próprio doc
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Pedidos — o usuário cria/lê os próprios; admin vê tudo
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Estampas (costas/frente) — leitura pública na loja; CRUD só admin
    match /stamps/{stampId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Cupons — leitura pública (checkout valida), CRUD só admin.
    // Usuário logado pode incrementar usedCount ao finalizar pagamento.
    match /coupons/{couponId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount'])
        && request.resource.data.usedCount == resource.data.usedCount + 1
      );
    }

    // Leads — qualquer um pode criar (formulário de WhatsApp no site).
    // Leitura/remoção somente admin.
    match /leads/{leadId} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if isAdmin();
    }
  }
}
